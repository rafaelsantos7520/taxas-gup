<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tabela de Entregas Guarapari</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            padding: 20px;
        }
        .container {
            max-width: 600px;
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.1);
        }
        h1 {
            text-align: center;
            margin-bottom: 20px;
        }
        label {
            margin-top: 10px;
        }
        #resultado {
            margin-top: 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Tabela de Entregas - Guarapari</h1>
        <div class="mb-3">
            <label for="origem" class="form-label">Selecione a Origem:</label>
            <select id="origem" class="form-select">
                <option value="">Escolha a origem</option>
                <option value="Muquiçaba">Muquiçaba</option>
                <option value="Praia do Morro">Praia do Morro</option>
                <option value="Centro">Centro</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="destino" class="form-label">Selecione o Destino:</label>
            <select id="destino" class="form-select">
                <option value="">Escolha o destino</option>
                <option value="Muquiçaba">Muquiçaba</option>
                <option value="Praia do Morro">Praia do Morro</option>
                <option value="Centro">Centro</option>
                <option value="Itapebuçú">Itapebuçú</option>
                <option value="Aeroporto">Aeroporto</option>
                <option value="Santa Rosa">Santa Rosa</option>
                <option value="Jardim Boa Vista">Jardim Boa Vista</option>
                <option value="Jardim Santa Rosa">Jardim Santa Rosa</option>
                <option value="Jabaraí">Jabaraí</option>
                <option value="Portal Clube">Portal Clube</option>
                <option value="Perocão">Perocão</option>
                <option value="Santa Mônica">Santa Mônica</option>
                <option value="Setiba">Setiba</option>
                <option value="Adalberto">Adalberto</option>
                <option value="Lagoa Funda">Lagoa Funda</option>
                <option value="Sol Nascente">Sol Nascente</option>
                <option value="São José">São José</option>
                <option value="São Gabriel">São Gabriel</option>
                <option value="Nossa Senhora da Conceição">Nossa Senhora da Conceição</option>
                <option value="Bela Vista">Bela Vista</option>
                <option value="Nossa Senhora de Fátima">Nossa Senhora de Fátima</option>
                <option value="Rodoviária">Rodoviária</option>
                <option value="Ipiranga">Ipiranga</option>
                <option value="Olaria">Olaria</option>
                <option value="Kubitschek">Kubitschek</option>
                <option value="Coronado">Coronado</option>
                <option value="Concha da Ostra">Concha da Ostra</option>
                <option value="Praia do Riacho">Praia do Riacho</option>
                <option value="Lameirão">Lameirão</option>
                <option value="Nova Guarapari">Nova Guarapari</option>
                <option value="Meaípe">Meaípe</option>
                <option value="Condados">Condados</option>
                <option value="Porto Grande">Porto Grande</option>
                <option value="Mãe-bá">Mãe-bá</option>
                <option value="Taquaras">Taquaras</option>
                <option value="Praia do Sol">Praia do Sol</option>
            </select>
        </div>

        <p id="resultado" class="alert alert-primary"></p>
    </div>

    <script>
        const valoresEntrega = {
            "Muquiçaba": {
                "Muquiçaba": 7.00,
