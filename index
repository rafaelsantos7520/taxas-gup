        document.getElementById('origem').addEventListener('change', calcularValor);
        document.getElementById('destino').addEventListener('change', calcularValor);

        function calcularValor() {
            const origem = document.getElementById('origem').value;
            const destino = document.getElementById('destino').value;

            if (origem && destino) {
                const valor = valoresEntrega[origem][destino] || valoresEntrega[destino][origem];
                if (valor) {
                    document.getElementById('resultado').innerText = `O valor da entrega de ${origem} para ${destino} é R$ ${valor.toFixed(2)}`;
                } else {
                    document.getElementById('resultado').innerText = 'Desculpe, não há valores disponíveis para esta rota.';
                }
            }
        }
    </script>
</body>
</html>
